# =======================================
# Django Core Settings
# =======================================
# CRITICAL: Generate a new secret key for production
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-use-django-generate-secret-key

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1

# =======================================
# Database Configuration
# =======================================
# For development (SQLite)
DB_ENGINE=django.db.backends.sqlite3

# For production (PostgreSQL) - uncomment and configure
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=studex_db
# DB_USER=postgres
# DB_PASSWORD=your-secure-database-password
# DB_HOST=localhost
# DB_PORT=5432

# =======================================
# CORS & Security Settings
# =======================================
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend URL (for redirects and email links)
FRONTEND_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# =======================================
# Rate Limiting (requests per minute)
# =======================================
RATE_LIMIT_LOGIN=10
RATE_LIMIT_REGISTER=5
RATE_LIMIT_API=60
RATE_LIMIT_FILE_UPLOAD=20

# =======================================
# File Upload Security
# =======================================
# Maximum file size in MB
MAX_UPLOAD_SIZE_MB=10

# Allowed image extensions (comma-separated)
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,gif,webp

# Allowed document extensions (comma-separated)
ALLOWED_DOCUMENT_EXTENSIONS=pdf,doc,docx

# =======================================
# Payment Gateway (Paystack)
# =======================================
# Get from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# =======================================
# Firebase Authentication
# =======================================
# Place firebase_service_account.json in the parent directory
# Download from Firebase Console > Project Settings > Service Accounts

# =======================================
# Email Configuration
# =======================================
# For development (console backend)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# For production (SMTP) - uncomment and configure
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-gmail-app-password

# =======================================
# JWT Token Settings
# =======================================
# Access token lifetime in days
JWT_ACCESS_TOKEN_LIFETIME=1

# Refresh token lifetime in days
JWT_REFRESH_TOKEN_LIFETIME=7

# =======================================
# University Email Validation
# =======================================
# Comma-separated list of allowed email domains
# Leave empty or comment out to allow all domains (development)
# ALLOWED_UNIVERSITY_DOMAINS=pau.edu.ng,student.pau.edu.ng

# =======================================
# Security Headers (Production)
# =======================================
# Enable secure cookies in production (requires HTTPS)
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# =======================================
# Logging
# =======================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =======================================
# Blockchain Integration (Future)
# =======================================
# BLOCKCHAIN_RPC_URL=https://polygon-rpc.com
# BLOCKCHAIN_PRIVATE_KEY=your_polygon_private_key_here
# BLOCKCHAIN_CONTRACT_ADDRESS=0x...
